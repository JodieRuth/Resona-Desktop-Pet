# =============================================================================
# Pack Override Configuration File
# =============================================================================
# 
# 功能说明:
#   此文件用于为特定资源包覆盖程序的主配置。
#   当该Pack被激活时，此文件中定义的配置项会优先于主配置生效。
#   未在此文件中定义的配置项将继续使用主配置的设置。
#
# 使用方法:
#   1. 将此文件重命名为 "override_config.cfg"
#   2. 编辑 "override_config.cfg"，添加需要覆盖的配置项
#   3. 重启程序或切换到该Pack即可生效
#
# 注意事项:
#   - 只需包含需要覆盖的配置项，不需要复制整个config.cfg
#   - 格式与config.cfg相同，使用INI格式
#   - 切换到其他没有override_config.cfg的Pack时，会自动恢复主配置
#   - 此文件不会覆盖主config.cfg文件，仅在运行时生效

# =============================================================================
# 使用示例:
# =============================================================================
# 假设你想让这个Pack使用更大的窗口和更长的文本显示时间:
#
# [General]
# width = 900
# height = 1000
# text_read_speed = 0.3
# base_display_time = 3.0
#
# 保存后，切换到该Pack时:
# - 窗口尺寸会变为 900x1000
# - 文本显示时间会变长
# - 其他设置保持主配置不变
# =============================================================================
